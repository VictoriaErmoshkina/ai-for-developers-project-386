{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/frontend/*"],
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": ["src/frontend", "src/shared", "vite.config.ts"]
}